<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Materia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>:root { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="flex items-center justify-center min-h-screen p-4"
      style="background: linear-gradient(135deg, #0d3f6e 0%, #1370a2 50%, #0f6e56 100%);">

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-lg">

        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">
            Registrar Materia
        </h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
            {{successMessage}}
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
            {{errorMessage}}
        </div>
        {{/errorMessage}}

        <form action="/subject/new" method="post" class="space-y-4">

            <!-- Código -->
            <div>
                <label for="code"
                       class="block text-gray-700 text-sm font-medium mb-1">
                    Código
                </label>
                <input type="number"
                       id="code"
                       name="code"
                       required
                       min="1"
                       title="Ingrese el código numérico de la materia"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500">
            </div>

            <!-- Nombre -->
            <div>
                <label for="name"
                       class="block text-gray-700 text-sm font-medium mb-1">
                    Nombre
                </label>
                <input type="text"
                       id="name"
                       name="name"
                       required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500">
            </div>

            <!-- Plan de estudio -->
            <div>
                <label for="course_syllabus"
                       class="block text-gray-700 text-sm font-medium mb-1">
                    Plan de estudio
                </label>
                <textarea id="course_syllabus"
                          name="course_syllabus"
                          rows="4"
                          class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500 resize-none"></textarea>
            </div>

            <!-- Horas -->
            <div>
                <label for="hours"
                       class="block text-gray-700 text-sm font-medium mb-1">
                    Cantidad de horas
                </label>
                <input type="number"
                       id="hours"
                       name="hours"
                       required
                       min="1"
                       title="La cantidad de horas debe ser mayor a cero"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500">
            </div>

            <button type="submit"
                    class="w-full bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700 transition duration-300">
                Registrar Materia
            </button>

            <div class="text-center mt-4">
                <a href="/dashboard"
                   class="text-amber-600 hover:underline text-sm">
                    Volver al Dashboard
                </a>
            </div>

        </form>
    </div>
</body>
</html>
