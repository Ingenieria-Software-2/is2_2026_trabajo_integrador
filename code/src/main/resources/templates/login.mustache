<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Iniciar Sesión — Sistema Universitario</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-4"
      style="background-color: #1D9E75;">

    <!-- Header -->
    <div class="text-center mb-6">
        <h1 class="text-3xl font-medium text-white mb-1">Sistema universitario</h1>
        <p class="text-sm" style="color: #9FE1CB;">Gestión académica centralizada</p>
    </div>

    <!-- Badges de roles -->
    <div class="flex gap-2 mb-6">
        <span class="text-xs px-3 py-1 rounded-full" 
              style="background: rgba(255,255,255,0.15); color: #E1F5EE;">Alumnos</span>
        <span class="text-xs px-3 py-1 rounded-full" 
              style="background: rgba(255,255,255,0.15); color: #E1F5EE;">Docentes</span>
        <span class="text-xs px-3 py-1 rounded-full" 
              style="background: rgba(255,255,255,0.15); color: #E1F5EE;">Administradores</span>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-xl p-6 w-full max-w-sm shadow-sm">

        {{#successMessage}}
        <div class="text-sm px-3 py-2 rounded-lg mb-4"
             style="background: #E1F5EE; border: 0.5px solid #1D9E75; color: #085041;">
            {{successMessage}}
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="text-sm px-3 py-2 rounded-lg mb-4"
             style="background: #FCEBEB; border: 0.5px solid #E24B4A; color: #791F1F;">
            {{errorMessage}}
        </div>
        {{/errorMessage}}

        <form action="/login" method="post" class="space-y-4">
            <div>
                <label for="username" class="block text-sm mb-1"
                       style="color: #5F5E5A;">Nombre de usuario</label>
                <input type="text" id="username" name="username" required
                       placeholder="tu usuario"
                       class="w-full px-3 py-2 text-sm rounded-lg border focus:outline-none focus:ring-2"
                       style="border-color: #D3D1C7; focus-ring-color: #1D9E75;">
            </div>
            <div>
                <label for="password" class="block text-sm mb-1"
                       style="color: #5F5E5A;">Contraseña</label>
                <input type="password" id="password" name="password" required
                       placeholder="••••••••"
                       class="w-full px-3 py-2 text-sm rounded-lg border focus:outline-none focus:ring-2"
                       style="border-color: #D3D1C7;">
            </div>
            <button type="submit"
                    class="w-full py-2 px-4 rounded-lg text-sm font-medium text-white transition-colors"
                    style="background-color: #1D9E75;"
                    onmouseover="this.style.backgroundColor='#0F6E56'"
                    onmouseout="this.style.backgroundColor='#1D9E75'">
                Iniciar sesión
            </button>
        </form>

        <p class="text-center text-xs mt-4" style="color: #888780;">
            ¿No tenés cuenta?
            <a href="/user/new" style="color: #1D9E75;" class="hover:underline">
                Registrate aquí
            </a>
        </p>
    </div>

</body>
</html>