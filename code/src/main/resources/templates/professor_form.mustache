<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registro de Profesor</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Registrar Nuevo Profesor</h1>

        {{#successMessage}}
        <!-- Estilo de mensaje de éxito idéntico al user_form -->
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <!-- Estilo de mensaje de error idéntico al user_form -->
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/professor/new" method="post" class="space-y-4">
            <!-- SECCIÓN OBLIGATORIA: DATOS DE PERSONA -->
            <h2 class="text-xl font-semibold text-gray-700 mb-2">Información Obligatoria
                <span class="text-red-500 text-sm">(*)</span>
            </h2>

            <div>
                <label for="nombre" class="block text-gray-700 text-sm font-medium mb-1">Nombre (*):</label>
                <input type="text" id="nombre" name="nombre" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="apellido" class="block text-gray-700 text-sm font-medium mb-1">Apellido (*):</label>
                <input type="text" id="apellido" name="apellido" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="dni" class="block text-gray-700 text-sm font-medium mb-1">DNI (Número) (*):</label>
                <!-- CORRECCIÓN CLAVE: Usamos type="text" con inputmode="numeric" para evitar problemas de parsing en el servidor -->
                <input type="text" id="dni" name="dni" required
                        inputmode="numeric"
                        pattern="[0-9]{7,10}"
                        title="El DNI debe contener solo números, entre 7 y 10 dígitos."
                        placeholder="Ej: 30123456"
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="mail" class="block text-gray-700 text-sm font-medium mb-1">Correo Electrónico (*):</label>
                <input type="email" id="mail" name="mail" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <!-- SECCIÓN OPCIONAL: DATOS DE PROFESOR -->
            <h2 class="text-xl font-semibold text-gray-700 mb-2 pt-4 border-t border-gray-200">Información Opcional
            </h2>

            <div>
                <label for="legajo" class="block text-gray-700 text-sm font-medium mb-1">Legajo (Número):</label>
                <!-- CORRECCIÓN CLAVE: Usamos type="text" con inputmode="numeric" para asegurar que un campo vacío no cause un crash -->
                <input type="text" id="legajo" name="legajo"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        placeholder="Dejar vacío si no aplica"
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="titulo" class="block text-gray-700 text-sm font-medium mb-1">Título:</label>
                <input type="text" id="titulo" name="titulo"
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="universidad" class="block text-gray-700 text-sm font-medium mb-1">Universidad de Graduación:</label>
                <input type="text" id="universidad" name="universidad"
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="cargo" class="block text-gray-700 text-sm font-medium mb-1">Cargo:</label>
                <input type="text" id="cargo" name="cargo"
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <button type="submit"
                    class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 mt-6">
                Registrar Profesor
            </button>
            <div class="text-center mt-4">
                <!-- El enlace se corrigió para ir al dashboard -->
                <a href="/dashboard" class="text-blue-600 hover:underline text-sm">Cancelar</a>
            </div>
        </form>
    </div>
</body>
</html>
