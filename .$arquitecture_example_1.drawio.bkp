-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;en sesión:&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;background-color: rgb(40, 42, 54); line-height: 19px;&quot;&gt;&lt;div style=&quot;color: rgb(204, 227, 245); font-family: &amp;quot;AnonymicePro Nerd Font&amp;quot;, &amp;quot;Droid Sans Mono&amp;quot;, &amp;quot;monospace&amp;quot;, monospace, &amp;quot;Droid Sans Mono&amp;quot;, monospace; white-space: pre; text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt; &lt;span style=&quot;color: #ffff81;&quot;&gt;Map&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #ffff81;&quot;&gt;String&lt;/span&gt;, &lt;span style=&quot;color: #ffff81;&quot;&gt;Object&lt;/span&gt;&amp;gt; &lt;span style=&quot;color: #00ffab;&quot;&gt;model&lt;/span&gt; &lt;span style=&quot;color: #83c5ff;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #ff80b8;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #81fff4;&quot;&gt;HashMap&lt;/span&gt;&amp;lt;&amp;gt;();&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 227, 245); font-family: &amp;quot;AnonymicePro Nerd Font&amp;quot;, &amp;quot;Droid Sans Mono&amp;quot;, &amp;quot;monospace&amp;quot;, monospace, &amp;quot;Droid Sans Mono&amp;quot;, monospace; white-space: pre; text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt; &lt;span style=&quot;color: #00ffab;&quot;&gt;model&lt;/span&gt;.&lt;span style=&quot;color: #81fff4;&quot;&gt;put&lt;/span&gt;(&lt;span style=&quot;color: #b083ff;&quot;&gt;&quot;username&quot;&lt;/span&gt;, &lt;span style=&quot;color: #00ffab;&quot;&gt;user&lt;/span&gt;.&lt;span style=&quot;color: #81fff4;&quot;&gt;getName&lt;/span&gt;());&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 227, 245); font-family: &amp;quot;AnonymicePro Nerd Font&amp;quot;, &amp;quot;Droid Sans Mono&amp;quot;, &amp;quot;monospace&amp;quot;, monospace, &amp;quot;Droid Sans Mono&amp;quot;, monospace; white-space: pre; text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt; &lt;span style=&quot;color: #ff80b8;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #ffff81;&quot;&gt;templateEngine&lt;/span&gt;.&lt;span style=&quot;color: #81fff4;&quot;&gt;render&lt;/span&gt;(&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 227, 245); font-family: &amp;quot;AnonymicePro Nerd Font&amp;quot;, &amp;quot;Droid Sans Mono&amp;quot;, &amp;quot;monospace&amp;quot;, monospace, &amp;quot;Droid Sans Mono&amp;quot;, monospace; white-space: pre; text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;     &lt;span style=&quot;color: #ff80b8;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #81fff4;&quot;&gt;ModelAndView&lt;/span&gt;(&lt;span style=&quot;color: #00ffab;&quot;&gt;model&lt;/span&gt;, &lt;span style=&quot;color: #b083ff;&quot;&gt;&quot;dashboard.mustache&quot;&lt;/span&gt;));&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font color=&quot;#cce3f5&quot; face=&quot;AnonymicePro Nerd Font, Droid Sans Mono, monospace, monospace, Droid Sans Mono, monospace&quot;&gt;&lt;span style=&quot;font-size: 14px; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
