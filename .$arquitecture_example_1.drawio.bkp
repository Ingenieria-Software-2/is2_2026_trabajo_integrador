        <mxCell id="E0HWw_Jm2xrX7lJcNsn0-20" parent="E0HWw_Jm2xrX7lJcNsn0-18" style="rounded=1;whiteSpace=wrap;html=1;align=center;" value="&lt;h1 style=&quot;line-height: 110%;&quot;&gt;&lt;span style=&quot;font-size: 22px;&quot;&gt;DBConfigSingleton.openConnection()&lt;/span&gt;&lt;/h1&gt;&lt;div&gt;&lt;div style=&quot;color: rgb(204, 227, 245); background-color: rgb(40, 42, 54); font-family: &amp;quot;AnonymicePro Nerd Font&amp;quot;, &amp;quot;Droid Sans Mono&amp;quot;, &amp;quot;monospace&amp;quot;, monospace, &amp;quot;Droid Sans Mono&amp;quot;, monospace; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;color: #81fff4;&quot;&gt;before&lt;/span&gt;((&lt;span style=&quot;color: #00ffab;font-style: italic;&quot;&gt;req&lt;/span&gt;, &lt;span style=&quot;color: #00ffab;font-style: italic;&quot;&gt;res&lt;/span&gt;) &lt;span style=&quot;color: #ff80b8;&quot;&gt;-&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;            &lt;span style=&quot;color: #ff80b8;&quot;&gt;try&lt;/span&gt; {&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;                &lt;span style=&quot;color: #00ffab;font-style: italic;&quot;&gt;dbConfig&lt;/span&gt;.&lt;span style=&quot;color: #81fff4;&quot;&gt;openConnection&lt;/span&gt;();&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;            } &lt;span style=&quot;color: #ff80b8;&quot;&gt;catch&lt;/span&gt; (&lt;span style=&quot;color: #ffff81;&quot;&gt;Exception&lt;/span&gt; &lt;span style=&quot;color: #00ffab;font-style: italic;&quot;&gt;e&lt;/span&gt;) {&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;                &lt;span style=&quot;color: #ffff81;&quot;&gt;System&lt;/span&gt;.&lt;span style=&quot;color: #ffff81;&quot;&gt;err&lt;/span&gt;.&lt;span style=&quot;color: #81fff4;&quot;&gt;println&lt;/span&gt;(&lt;span style=&quot;color: #b083ff;&quot;&gt;&quot;Error al abrir conexión: &quot;&