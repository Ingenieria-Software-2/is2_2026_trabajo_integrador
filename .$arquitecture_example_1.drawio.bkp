        <mxCell id="E0HWw_Jm2xrX7lJcNsn0-3" parent="E0HWw_Jm2xrX7lJcNsn0-18" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;h1&gt;&lt;span style=&quot;font-size: 22px;&quot;&gt;Component: UserRoutes&lt;/span&gt;&lt;/h1&gt;&lt;pre&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-family: Helvetica; font-size: 22px; white-space: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;File: UserRoutes.java&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&lt;div style=&quot;font-size: 22px; text-align: left;&quot;&gt;Descripción: Mapa de rutas a los endpoints de&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;la app:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;div style=&quot;color: rgb(204, 227, 245); background-color: rgb(40, 42, 54); font-family: &amp;quot;AnonymicePro Nerd Font&amp;quot;, &amp;quot;Droid Sans Mono&amp;quot;, &amp;quot;monospace&amp;quot;, monospace, &amp;quot;Droid Sans Mono&amp;quot;, monospace; line-height: 19px; white-space: pre;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 23px;&quot;&gt;        &lt;span style=&quot;color: rgb(129, 255, 244);&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: rgb(176, 131, 255);&quot;&gt;&quot;/&quot;&lt;/span&gt;,              &lt;span style=&quot;color: rgb(255, 255, 129);&quot;&gt;controller&lt;/span&gt;&lt;span style=&quot;color: rgb(255, 128, 184);&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: rgb(129, 255, 244);&quot;&gt;showLoginForm&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 23px;&quot;&gt;        &lt;span style=&quot;color: #81fff4;&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: #b083ff;&quot;&gt;&quot;/user/new&quot;&lt;/span&gt;,   &lt;span style=&quot;color: #ffff81;&quot;&gt;controller&lt;/span&gt;&lt;span style=&quot;color: #ff80b8;&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: #81fff4;&quot;&gt;showCreateForm&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 23px;&quot;&gt;        &lt;span style=&quot;color: #81fff4;&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: #b083ff;&quot;&gt;&quot;/dashboard&quot;&lt;/span&gt;,     &lt;span style=&quot;color: #ffff81;&quot;&gt;controller&lt;/span&gt;&lt;span style=&quot;color: #ff80b8;&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: #81fff4;&quot;&gt;showDashboard&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 23px;&quot;&gt;        &lt;span style=&quot;color: #81fff4;&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: #b083ff;&quot;&gt;&quot;/logout&quot;&lt;/span&gt;,        &lt;span style=&quot;color: #ffff81;&quot;&gt;controller&lt;/span&gt;&lt;span style=&quot;color: #ff80b8;&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: #81fff4;&quot;&gt;logout&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 23px;&quot;&gt;        &lt;span style=&quot;color: #81fff4;&quot;&gt;post&lt;/span&gt;(&lt;span style=&quot;color: #b083ff;&quot;&gt;&quot;/user/new&quot;&lt;/span&gt;,     &lt;span style=&quot;color: #ffff81;&quot;&gt;controller&lt;/span&gt;&lt;span style=&quot;color: #ff80b8;&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: #81fff4;&quot;&gt;create&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 23px;&quot;&gt;        &lt;span style=&quot;color: rgb(129, 255, 244);&quot;&gt;post&lt;/span&gt;(&lt;span style=&quot;color: rgb(176, 131, 255);&quot;&gt;&quot;/login&quot;&lt;/span&gt;,        &lt;span style=&quot;color: rgb(255, 255, 129);&quot;&gt;controller&lt;/span&gt;&lt;span style=&quot;color: rgb(255, 128, 184);&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: rgb(129, 255, 244);&quot;&gt;login&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/pre&gt;" vertex="1">
