        <mxCell id="E0HWw_Jm2xrX7lJcNsn0-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=1;" value="&lt;h1&gt;&lt;u&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;Inicio&lt;/font&gt;&lt;/u&gt;&lt;/h1&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
